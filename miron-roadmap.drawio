        <mxCell id="d1_2_text" value="• Salebot: создать бота\n• Подключить Робокассу\n• Создать 3 переменные: {score_A/B/C}" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontColor=#3A352F;spacingLeft=5;" vertex="1" parent="1">
