        <mxCell id="cl6" value="☐ Голос Мирона (ElevenLabs)" style="text;html=1;strokeColor=none;fillColor=#FAF6F0;align=left;fontSize=12;fontColor=#3A352F;spacingLeft=5;" vertex="1" parent="1">
